  {lbl:'ETF BTC flux',val:'+$420M',tr:'bull',note:'Entrées nettes 3j'},
];

let S={prices:{},changes:{},selected:'bitcoin',tf:'1h',chart:null,klines:{},rsi:{},alerts:[],lastAlert:{},lastTgAlert:{},soundOn:false,tgOk:false};
let AC=null;
function getAC(){if(!AC)AC=new(window.AudioContext||window.webkitAudioContext)();return AC;}
function playBeep(f,t,d){try{const ac=getAC(),o=ac.createOscillator(),g=ac.createGain();o.connect(g);g.connect(ac.destination);o.type=t;o.frequency.value=f;g.gain.setValueAtTime(0.3,ac.currentTime);g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+d);o.start();o.stop(ac.currentTime+d);}catch(e){}}
function alertSound(dir){if(!S.soundOn)return;const ac=getAC();if(ac.state==='suspended')ac.resume();if(dir==='long'){playBeep(880,'sine',0.15);setTimeout(()=>playBeep(1100,'sine',0.2),180);}else if(dir==='short'){playBeep(440,'sawtooth',0.15);setTimeout(()=>playBeep(330,'sawtooth',0.2),180);}}

function showTab(t,btn){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('tab-'+t).classList.add('on');
  btn.classList.add('on');
  if(t==='graphique')setTimeout(renderChart,80);
}

function fmt(n){if(!n||isNaN(n))return'—';if(n>=10000)return'$'+Math.round(n).toLocaleString('fr-FR');if(n>=100)return'$'+n.toFixed(1);return'$'+n.toFixed(2);}
function fmtPct(n){if(isNaN(n))return'—';return(n>=0?'+':'')+n.toFixed(2)+'%';}

function calcRSI(closes,period=14){
  if(closes.length<period+1)return 50;
  let g=0,l=0;
  for(let i=1;i<=period;i++){const d=closes[i]-closes[i-1];if(d>0)g+=d;else l+=Math.abs(d);}
  let ag=g/period,al=l/period;
  for(let i=period+1;i<closes.length;i++){const d=closes[i]-closes[i-1];ag=(ag*(period-1)+(d>0?d:0))/period;al=(al*(period-1)+(d<0?Math.abs(d):0))/period;}
  return al===0?100:100-(100/(1+ag/al));
}

function detectBOS(kl){
  if(kl.length<12)return{type:null,level:null,choch:false};
  const n=kl.length,last=kl[n-1].c;
  const pH=Math.max(...kl.slice(-10,-1).map(k=>k.h));
  const pL=Math.min(...kl.slice(-10,-1).map(k=>k.l));
  const ppH=Math.max(...kl.slice(-20,-10).map(k=>k.h));
  const ppL=Math.min(...kl.slice(-20,-10).map(k=>k.l));
  let type=null,level=null,choch=false;
  if(last>pH){type='bull';level=pH;if(pH<ppH)choch=true;}
  else if(last<pL){type='bear';level=pL;if(pL>ppL)choch=true;}
  return{type,level,choch};
}

function computeSignal(sym,ch24,rsi,kl){
  let score=0,reasons=[];
  if(ch24>2){score+=25;reasons.push('Momentum haussier 24h');}else if(ch24<-2){score-=25;reasons.push('Momentum baissier 24h');}
  if(rsi<35){score+=30;reasons.push('RSI survendu ('+Math.round(rsi)+')');}else if(rsi>68){score-=30;reasons.push('RSI suracheté ('+Math.round(rsi)+')');}else if(rsi>50&&rsi<68){score+=10;reasons.push('RSI zone haussière');}
  const geo=GEO.reduce((a,e)=>a+e.imp,0);
  if(geo>0){score+=15;reasons.push('Géopolitique favorable');}else if(geo<0){score-=15;reasons.push('Tensions macro actives');}
  if(sym==='BTC'){score+=10;reasons.push('Flux ETF positifs');}
  const bos=detectBOS(kl);
  if(bos.type==='bull'){score+=25;reasons.push(bos.choch?'CHoCH haussier détecté':'BOS haussier confirmé');}
  else if(bos.type==='bear'){score-=25;reasons.push(bos.choch?'CHoCH baissier détecté':'BOS baissier confirmé');}
  if(kl.length>3){const l=kl.slice(-3);if(l[2].c>l[1].c&&l[1].c>l[0].c){score+=15;reasons.push('3 bougies haussières');}if(l[2].c<l[1].c&&l[1].c<l[0].c){score-=15;reasons.push('3 bougies baissières');}}
  let label,dir;
  if(score>=40){label='LONG';dir='long';}else if(score<=-30){label='SHORT';dir='short';}else{label='ATTENTE';dir='wait';}
  return{label,dir,score,conf:Math.min(95,Math.abs(score)+20),reasons,bos};
}

function log(msg){const el=document.getElementById('tgLog');if(el)el.textContent=msg;}

async function sendTelegram(msg){
  try{
    const r=await fetch('https://api.telegram.org/bot'+TG_TOKEN+'/sendMessage',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({chat_id:TG_CHAT,text:msg,parse_mode:'HTML'})
    });
    const d=await r.json();
    if(d.ok){
      S.tgOk=true;
      const btn=document.getElementById('tgTestBtn');
      if(btn){btn.className='tg-btn tg-ok';btn.textContent='✅ Telegram connecté !';}
      const sl=document.getElementById('tgStatusLabel');
      if(sl){sl.textContent='Connecté ✓';sl.style.color='var(--up)';}
      log('✓ Message envoyé à '+new Date().toLocaleTimeString('fr-FR'));
    }else{
      const sl=document.getElementById('tgStatusLabel');
      if(sl){sl.textContent='Erreur ✗';sl.style.color='var(--dn)';}
      log('✗ Erreur Telegram : '+(d.description||JSON.stringify(d)));
    }
    return d.ok;
  }catch(e){
    log('✗ Erreur réseau : '+e.message+'\nAssure-toi d\'ouvrir ce fichier dans Safari.');
    return false;
  }
}

async function testTelegram(){
