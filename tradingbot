}

function toggleSound(){
  const ac=getAC();if(ac.state==='suspended')ac.resume();
  S.soundOn=!S.soundOn;
  const btn=document.getElementById('soundBtn');
  btn.textContent=S.soundOn?'🔊 Son ON — alertes audio actives':'🔇 Son OFF — appuie pour activer';
  btn.className=S.soundOn?'sound-btn on':'sound-btn';
  if(S.soundOn)alertSound('long');
}

async function fireAlerts(sym,sig,rsi,coin){
  const threshold=parseInt(document.getElementById('threshold').value);
  const key=sym+sig.dir,now=Date.now();
  if(sig.conf>=threshold&&sig.dir!=='wait'&&(!S.lastAlert[key]||now-S.lastAlert[key]>120000)){
    S.lastAlert[key]=now;
    const emoji=sig.dir==='long'?'🟢':'🔴';
    const msg=emoji+' <b>'+sig.label+' '+sym+'</b>\n\nConfiance : <b>'+sig.conf+'%</b>\nRSI : '+Math.round(rsi)+'\n\nRaisons :\n'+sig.reasons.map(r=>'· '+r).join('\n')+'\n\nPrix : '+fmt(S.prices[coin.id])+'\n⏰ '+new Date().toLocaleTimeString('fr-FR');
    alertSound(sig.dir);
    S.alerts.unshift({type:sig.dir,msg:sig.label+' '+sym+' · '+sig.conf+'% conf. · '+sig.reasons[0],tm:'à l\'instant'});
    if(S.alerts.length>10)S.alerts.pop();
    if((sig.dir==='long'&&document.getElementById('tgLong').checked)||(sig.dir==='short'&&document.getElementById('tgShort').checked))await sendTelegram(msg);
  }
  if(sig.bos&&sig.bos.type&&(!S.lastTgAlert['bos'+sym]||now-S.lastTgAlert['bos'+sym]>300000)){
    S.lastTgAlert['bos'+sym]=now;
    const bt=sig.bos.choch?'CHoCH':'BOS',bd=sig.bos.type==='bull'?'HAUSSIER':'BAISSIER';
    S.alerts.unshift({type:sig.bos.type==='bull'?'long':'short',msg:bt+' '+bd+' '+sym+' · niveau '+fmt(sig.bos.level),tm:'à l\'instant'});
    if(S.alerts.length>10)S.alerts.pop();
    if(document.getElementById('tgBos').checked)await sendTelegram((sig.bos.choch?'🔄':'💥')+' <b>'+bt+' '+bd+' — '+sym+'</b>\n\nNiveau cassé : '+fmt(sig.bos.level)+'\nPrix actuel : '+fmt(S.prices[coin.id])+'\n⏰ '+new Date().toLocaleTimeString('fr-FR'));
  }
  if(document.getElementById('tgRsi').checked){
    const rk='rsi'+sym+(rsi<30?'os':'ob');
    if((rsi<30||rsi>70)&&(!S.lastTgAlert[rk]||now-S.lastTgAlert[rk]>300000)){
      S.lastTgAlert[rk]=now;
      await sendTelegram((rsi<30?'📉':'📈')+' <b>RSI '+(rsi<30?'SURVENDU':'SURACHETÉ')+' — '+sym+'</b>\n\nRSI : <b>'+Math.round(rsi)+'</b>\nPrix : '+fmt(S.prices[coin.id])+'\n⏰ '+new Date().toLocaleTimeString('fr-FR'));
    }
  }
}

async function fetchKlines(pair,interval,limit=80){
  const r=await fetch('https://api.binance.com/api/v3/klines?symbol='+pair+'&interval='+interval+'&limit='+limit);
  const d=await r.json();
  return d.map(k=>({t:k[0],o:parseFloat(k[1]),h:parseFloat(k[2]),l:parseFloat(k[3]),c:parseFloat(k[4]),v:parseFloat(k[5])}));
}
async function fetchTicker(pair){const r=await fetch('https://api.binance.com/api/v3/ticker/24hr?symbol='+pair);return r.json();}

async function loadAll(){
  try{
    await Promise.all(COINS.map(async c=>{
      const[ticker,kl]=await Promise.all([fetchTicker(c.pair),fetchKlines(c.pair,S.tf)]);
      S.prices[c.id]=parseFloat(ticker.lastPrice);
      S.changes[c.id]=parseFloat(ticker.priceChangePercent);
      S.klines[c.id]=kl;
      S.rsi[c.id]=calcRSI(kl.map(k=>k.c));
    }));
    document.getElementById('upd').textContent=new Date().toLocaleTimeString('fr-FR');
    await Promise.all(COINS.map(async c=>{
      const rsi=S.rsi[c.id]||50;
      const sig=computeSignal(c.sym,S.changes[c.id]||0,rsi,S.klines[c.id]||[]);
      await fireAlerts(c.sym,sig,rsi,c);
    }));
    renderAll();
  }catch(e){document.getElementById('upd').textContent='Erreur réseau';}
}

function renderCards(){
  document.getElementById('cards').innerHTML=COINS.map(c=>{
    const p=S.prices[c.id]||0,ch=S.changes[c.id]||0,rsi=S.rsi[c.id]||50,kl=S.klines[c.id]||[];
    const sig=computeSignal(c.sym,ch,rsi,kl);
    return'<div class="ccard '+sig.dir+(S.selected===c.id?' active':'')+'" onclick="selectCoin(\''+c.id+'\')">'
      +'<div class="csym">'+c.sym+'/USDT</div>'
      +'<div class="cprice">'+fmt(p)+'</div>'
      +'<div class="cch '+(ch>=0?'pos':'neg')+'">'+fmtPct(ch)+'</div>'
      +'<div class="csig s'+sig.dir[0]+'">'+sig.label+'</div>'
      +'<div class="cconf">'+sig.conf+'% conf.</div>'
      +'</div>';
  }).join('');
  document.getElementById('coinSel').innerHTML=COINS.map(c=>'<button class="csel-btn'+(S.selected===c.id?' on':'')+'" onclick="selectCoin(\''+c.id+'\')">'+c.sym+'</button>').join('');
}

function renderMainSignal(){
  const c=COINS.find(x=>x.id===S.selected),kl=S.klines[S.selected]||[],rsi=S.rsi[S.selected]||50;
  const sig=computeSignal(c.sym,S.changes[S.selected]||0,rsi,kl);
  const el=document.getElementById('sigLabel');
  el.className='sigbig '+sig.dir;el.textContent=sig.label+' '+c.sym;
  document.getElementById('sigReason').innerHTML=sig.reasons.slice(0,4).map(r=>'· '+r).join('<br>');
  document.getElementById('sbw').innerHTML=[
    {lbl:'Technique',v:Math.min(100,Math.abs(sig.score)+15),cl:sig.dir==='long'?'fg':sig.dir==='short'?'fr':'fa'},
    {lbl:'Géopolitique',v:55,cl:'fa'},
    {lbl:'Confiance globale',v:sig.conf,cl:sig.dir==='long'?'fg':sig.dir==='short'?'fr':'fa'},
  ].map(b=>'<div class="slbl"><span>'+b.lbl+'</span><span>'+b.v+'%</span></div><div class="sbar"><div class="sfill '+b.cl+'" style="width:'+b.v+'%"></div></div>').join('');
}

function renderStruct(){
  const p=S.prices[S.selected]||S.prices['bitcoin']||84000,kl=S.klines[S.selected]||[];
  let s1=p*.975,s2=p*.955,r1=p*1.025,r2=p*1.045;
  if(kl.length>20){const sl=kl.slice(-20),lo=sl.map(k=>k.l).sort((a,b)=>a-b),hi=sl.map(k=>k.h).sort((a,b)=>b-a);s1=lo[2]||s1;s2=lo[4]||s2;r1=hi[2]||r1;r2=hi[4]||r2;}
  const bos=detectBOS(kl),trend=(S.changes[S.selected]||0)>0?'bull':'bear',rsi=S.rsi[S.selected]||50;
  document.getElementById('structRows').innerHTML=[
    {k:'Tendance',v:trend==='bull'?'Haussière ↑':'Baissière ↓',c:trend},
    {k:'BOS/CHoCH',v:bos.type?(bos.choch?'CHoCH':'BOS')+' '+(bos.type==='bull'?'↑':'↓'):'Aucun',c:bos.type||''},
    {k:'R2',v:'$'+Math.round(r2).toLocaleString('fr-FR'),c:''},
    {k:'R1',v:'$'+Math.round(r1).toLocaleString('fr-FR'),c:''},
    {k:'Prix actuel',v:fmt(p),c:''},
    {k:'S1',v:'$'+Math.round(s1).toLocaleString('fr-FR'),c:''},
    {k:'S2',v:'$'+Math.round(s2).toLocaleString('fr-FR'),c:''},
    {k:'RSI (14)',v:Math.round(rsi),c:rsi<35?'bull':rsi>68?'bear':''},
    {k:'Structure',v:trend==='bull'?'HH / HL':'LH / LL',c:trend},
  ].map(r=>'<div class="strow"><span class="stk">'+r.k+'</span><span class="stv '+r.c+'">'+r.v+'</span></div>').join('');
}

function renderAlerts(){
  const el=document.getElementById('alerts');
  if(!S.alerts.length){el.innerHTML='<div style="font-size:12px;color:var(--txt2)">En attente de signaux...</div>';return;}
  el.innerHTML=S.alerts.slice(0,5).map(a=>'<div class="alrt a'+(a.type==='long'?'l':a.type==='short'?'s':'i')+'"><span class="aico">'+(a.type==='long'?'▲':a.type==='short'?'▼':'●')+'</span><div><div class="amsg">'+a.msg+'</div><div class="atm">'+a.tm+'</div></div></div>').join('');
}

function renderGeo(){
  document.getElementById('geo').innerHTML=GEO.map(e=>'<div class="geo-item"><span class="gtag t'+e.tag+'">'+e.tl+'</span><div class="gtext">'+e.txt+'</div><div class="gtm">'+e.tm+'</div></div>').join('');
  document.getElementById('macro').innerHTML=MACRO.map(m=>'<div class="strow"><div><div class="stk">'+m.lbl+'</div><div style="font-size:10px;color:var(--txt2)">'+m.note+'</div></div><span class="stv '+m.tr+'">'+m.val+'</span></div>').join('');
}

function renderChart(){
  const c=COINS.find(x=>x.id===S.selected),kl=S.klines[S.selected]||[];
  if(!kl.length)return;
  document.getElementById('chartTitle').textContent=c.sym+'/USDT · '+S.tf;
  const last=kl[kl.length-1];
  document.getElementById('ohlcBar').innerHTML='<span>O <b style="color:var(--txt)">'+fmt(last.o)+'</b></span><span>H <b style="color:var(--up)">'+fmt(last.h)+'</b></span><span>L <b style="color:var(--dn)">'+fmt(last.l)+'</b></span><span>C <b style="color:var(--txt)">'+fmt(last.c)+'</b></span>';
  const rsi=S.rsi[S.selected]||50;
  document.getElementById('rsiv').textContent=Math.round(rsi);
  document.getElementById('rsic').style.left=Math.min(97,Math.max(3,rsi))+'%';
  document.getElementById('rsiv').style.color=rsi<35?'var(--up)':rsi>68?'var(--dn)':'var(--txt)';
  const lows=kl.map(k=>k.l),highs=kl.map(k=>k.h);
  const sl=kl.slice(-20),slo=sl.map(k=>k.l).sort((a,b)=>a-b),shi=sl.map(k=>k.h).sort((a,b)=>b-a);
  const s1=slo[2],r1=shi[2],bos=detectBOS(kl);
  const labels=kl.map(k=>{const d=new Date(k.t);if(S.tf==='1d')return d.toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit'});return d.getHours()+':'+String(d.getMinutes()).padStart(2,'0');});
  const ctx=document.getElementById('cv').getContext('2d');
  if(S.chart)S.chart.destroy();
  const datasets=[
    {label:'Corps',data:kl.map(k=>[Math.min(k.o,k.c),Math.max(k.o,k.c)]),backgroundColor:kl.map(k=>k.c>=k.o?'rgba(0,230,118,.75)':'rgba(255,23,68,.75)'),borderColor:kl.map(k=>k.c>=k.o?'#00e676':'#ff1744'),borderWidth:1,borderSkipped:false,barPercentage:.55},
    {label:'H',data:highs,type:'line',borderColor:'transparent',backgroundColor:'transparent',pointRadius:0,tension:0},
    {label:'L',data:lows,type:'line',borderColor:'transparent',backgroundColor:'transparent',pointRadius:0,tension:0},
    {label:'S1',data:Array(kl.length).fill(s1),type:'line',borderColor:'rgba(0,230,118,.5)',borderWidth:1,borderDash:[5,4],pointRadius:0,fill:false},
    {label:'R1',data:Array(kl.length).fill(r1),type:'line',borderColor:'rgba(255,23,68,.5)',borderWidth:1,borderDash:[5,4],pointRadius:0,fill:false},
  ];
  if(bos.level)datasets.push({label:'BOS',data:Array(kl.length).fill(bos.level),type:'line',borderColor:bos.type==='bull'?'rgba(41,121,255,.8)':'rgba(255,214,0,.8)',borderWidth:1.5,borderDash:[3,3],pointRadius:0,fill:false});
  S.chart=new Chart(ctx,{type:'bar',data:{labels,datasets},options:{responsive:true,maintainAspectRatio:false,animation:{duration:200},plugins:{legend:{display:false},tooltip:{callbacks:{title:i=>labels[i[0].dataIndex],label:i=>{const k=kl[i.dataIndex];if(!k)return'';return['O: '+fmt(k.o),'H: '+fmt(k.h),'L: '+fmt(k.l),'C: '+fmt(k.c)];}}}},scales:{x:{ticks:{color:'#8888aa',font:{size:9},maxTicksLimit:8,autoSkip:true},grid:{color:'rgba(255,255,255,0.04)'}},y:{min:Math.min(...lows)*.999,max:Math.max(...highs)*1.001,ticks:{color:'#8888aa',font:{size:9},callback:v=>v>=1000?'$'+Math.round(v/1000)+'k':'$'+v.toFixed(1)},grid:{color:'rgba(255,255,255,0.04)'}}}}});
}

function renderAll(){renderCards();renderMainSignal();renderStruct();renderAlerts();renderGeo();}
function selectCoin(id){S.selected=id;renderAll();loadSelected();}
async function loadSelected(){
  const c=COINS.find(x=>x.id===S.selected);
  try{const kl=await fetchKlines(c.pair,S.tf);S.klines[S.selected]=kl;S.rsi[S.selected]=calcRSI(kl.map(k=>k.c));renderAll();renderChart();}catch(e){}
}
function setTF(tf,btn){
  S.tf=tf;
  document.querySelectorAll('.tfb').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  loadSelected();
}

renderGeo();
loadAll();
setInterval(loadAll,30000);
</script>
