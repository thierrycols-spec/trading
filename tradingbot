<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#0a0a0f;--bg2:#12121a;--bg3:#1a1a26;
  --up:#00e676;--dn:#ff1744;--warn:#ffd600;--info:#2979ff;
  --txt:#e8e8f0;--txt2:#8888aa;--border:rgba(255,255,255,0.08);
}
html,body{background:var(--bg);color:var(--txt);font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;min-height:100vh;overflow-x:hidden}

.app{max-width:480px;margin:0 auto;padding:16px 12px 32px}

.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-top:env(safe-area-inset-top)}
.hdr-title{font-size:18px;font-weight:700;letter-spacing:-0.5px;color:var(--txt)}
.hdr-title span{color:var(--up)}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--up);display:inline-block;margin-right:8px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
.upd-time{font-size:11px;color:var(--txt2);font-variant-numeric:tabular-nums}

.tabs{display:flex;background:var(--bg2);border-radius:12px;padding:3px;margin-bottom:16px;gap:2px}
.tab{flex:1;font-size:11px;font-weight:600;padding:7px 4px;border:none;border-radius:9px;cursor:pointer;background:transparent;color:var(--txt2);transition:all .2s;text-align:center}
.tab.on{background:var(--bg3);color:var(--txt);box-shadow:0 1px 4px rgba(0,0,0,.4)}

.section{display:none}.section.on{display:block}

/* CARDS */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.ccard{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:12px;cursor:pointer;position:relative;overflow:hidden;transition:border-color .2s}
.ccard.active{border-color:var(--info)}
.ccard::after{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px}
.ccard.long::after{background:var(--up)}
.ccard.short::after{background:var(--dn)}
.ccard.wait::after{background:var(--warn)}
.csym{font-size:10px;font-weight:600;color:var(--txt2);letter-spacing:.05em;padding-left:8px}
.cprice{font-size:17px;font-weight:700;color:var(--txt);padding-left:8px;margin:3px 0;font-variant-numeric:tabular-nums}
.cch{font-size:12px;font-weight:600;padding-left:8px;font-variant-numeric:tabular-nums}
.cch.pos{color:var(--up)}.cch.neg{color:var(--dn)}
.csig{font-size:10px;font-weight:700;padding:3px 7px;border-radius:6px;display:inline-block;margin:5px 0 0 8px;letter-spacing:.03em}
.sl{background:rgba(0,230,118,.15);color:var(--up)}
.ss{background:rgba(255,23,68,.15);color:var(--dn)}
.sw{background:rgba(255,214,0,.15);color:var(--warn)}
.cconf{font-size:10px;color:var(--txt2);padding-left:8px;margin-top:2px}

/* BLOCS */
.pblk{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:14px;margin-bottom:10px}
.plbl{font-size:10px;font-weight:700;color:var(--txt2);letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}

/* SIGNAL */
.sigbox{background:var(--bg3);border-radius:12px;padding:14px;margin-bottom:10px}
.sigbig{font-size:28px;font-weight:800;margin-bottom:4px;letter-spacing:-1px}
.sigbig.long{color:var(--up)}.sigbig.short{color:var(--dn)}.sigbig.wait{color:var(--warn)}
.sigreason{font-size:12px;color:var(--txt2);line-height:1.7}
.sbw{margin-top:10px}
.slbl{font-size:10px;color:var(--txt2);margin-bottom:3px;display:flex;justify-content:space-between}
.sbar{height:4px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden;margin-bottom:6px}
.sfill{height:100%;border-radius:2px;transition:width .6s ease}
.fg{background:var(--up)}.fr{background:var(--dn)}.fa{background:var(--warn)}

/* STRUCTURE */
.strow{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px}
.strow:last-child{border-bottom:none}
.stk{color:var(--txt2)}.stv{font-weight:600;color:var(--txt);font-variant-numeric:tabular-nums}
.stv.bull{color:var(--up)}.stv.bear{color:var(--dn)}

/* ALERTES */
.alrt{display:flex;gap:8px;align-items:flex-start;padding:8px 10px;border-radius:10px;margin-bottom:6px;font-size:11px}
.alrt:last-child{margin-bottom:0}
.al{background:rgba(0,230,118,.07)}.as{background:rgba(255,23,68,.07)}.ai{background:rgba(41,121,255,.07)}
.aico{font-size:13px;margin-top:1px;flex-shrink:0}
.amsg{color:var(--txt);line-height:1.5;font-weight:500}
.atm{color:var(--txt2);font-size:10px;margin-top:2px}

/* GRAPHIQUE */
#cvWrap{position:relative;width:100%;height:220px;margin-bottom:10px}
.tfrow{display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap}
.tfb{font-size:11px;padding:5px 10px;border:1px solid var(--border);border-radius:8px;cursor:pointer;background:transparent;color:var(--txt2);font-weight:600}
.tfb.on{background:var(--info);color:#fff;border-color:var(--info)}
.rsirow{display:flex;align-items:center;gap:10px;margin-top:8px}
.rsig{flex:1;height:5px;background:linear-gradient(to right,var(--up) 0%,var(--warn) 30%,var(--up) 50%,var(--warn) 70%,var(--dn) 100%);border-radius:3px;position:relative}
.rsic{width:11px;height:11px;background:#fff;border:2px solid var(--bg);border-radius:50%;position:absolute;top:-3px;transform:translateX(-50%);transition:left .4s}
.rsiv{font-size:13px;font-weight:700;min-width:30px;text-align:right;font-variant-numeric:tabular-nums}
.ohlcbar{display:flex;gap:12px;margin-top:8px;font-size:11px;color:var(--txt2);flex-wrap:wrap;font-variant-numeric:tabular-nums}

/* TELEGRAM */
.tg-btn{width:100%;padding:16px;font-size:15px;font-weight:700;border-radius:14px;border:none;cursor:pointer;margin-bottom:10px;transition:all .2s;letter-spacing:.01em}
.tg-btn:active{transform:scale(.97)}
.tg-send{background:var(--info);color:#fff}
.tg-ok{background:rgba(0,230,118,.15);color:var(--up);border:1px solid rgba(0,230,118,.3)}
.tg-err{background:rgba(255,23,68,.1);color:var(--dn);border:1px solid rgba(255,23,68,.3)}
.tg-log{background:var(--bg3);border-radius:10px;padding:10px 12px;font-size:11px;color:var(--txt2);line-height:1.7;margin-top:8px;min-height:44px;word-break:break-all;font-variant-numeric:tabular-nums}
.check-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px;color:var(--txt);cursor:pointer}
.check-row:last-child{border-bottom:none}
.check-row input[type=checkbox]{width:18px;height:18px;accent-color:var(--up);cursor:pointer;flex-shrink:0}
.sound-btn{width:100%;padding:13px;font-size:13px;font-weight:600;border:1px solid var(--border);border-radius:12px;cursor:pointer;background:transparent;color:var(--txt2);margin-bottom:10px;transition:all .2s}
.sound-btn:active{transform:scale(.97)}
.sound-btn.on{background:rgba(0,230,118,.12);color:var(--up);border-color:rgba(0,230,118,.3)}
.threshold-row{display:flex;align-items:center;gap:10px;margin:6px 0;font-size:12px;color:var(--txt2)}
.threshold-row input[type=range]{flex:1;accent-color:var(--info)}
.tval{font-weight:700;color:var(--txt);min-width:34px;font-variant-numeric:tabular-nums}

/* GEO */
.geo-item{padding:8px 0;border-bottom:1px solid var(--border)}
.geo-item:last-child{border-bottom:none}
.gtag{font-size:9px;padding:2px 6px;border-radius:5px;font-weight:700;margin-right:5px;letter-spacing:.04em}
.tbear{background:rgba(255,23,68,.15);color:var(--dn)}
.tbull{background:rgba(0,230,118,.15);color:var(--up)}
.tneut{background:rgba(255,214,0,.15);color:var(--warn)}
.gtext{font-size:12px;color:var(--txt);line-height:1.5;margin-top:3px}
.gtm{font-size:10px;color:var(--txt2);margin-top:2px}

/* COIN SEL */
.coin-sel{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.csel-btn{font-size:12px;font-weight:600;padding:6px 14px;border:1px solid var(--border);border-radius:20px;cursor:pointer;background:transparent;color:var(--txt2);transition:all .15s}
.csel-btn.on{background:var(--info);color:#fff;border-color:var(--info)}

/* INSTALL HINT */
.install-hint{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:12px 14px;margin-bottom:12px;font-size:12px;color:var(--txt2);line-height:1.7}
.install-hint b{color:var(--txt)}
</style>
</head>
