<script>
const TG_TOKEN='8679052210:AAE1zC2Ivle9VwO4mKwa8SWf9UROOAnEKVg';
const TG_CHAT='509829267';
const COINS=[
  {id:'bitcoin',sym:'BTC',pair:'BTCUSDT'},
  {id:'ethereum',sym:'ETH',pair:'ETHUSDT'},
