];
const GEO=[
  {tag:'bear',tl:'BAISSIER',txt:'Trump annonce nouvelles taxes import Asie · pression risk assets',tm:'il y a 2h',imp:-1},
  {tag:'bull',tl:'HAUSSIER',txt:'Fonds souverain Abu Dhabi confirme allocation BTC 2%',tm:'il y a 4h',imp:1},
  {tag:'neutral',tl:'NEUTRE',txt:'Fed : FOMC sans surprise · statu quo juin probable',tm:'il y a 6h',imp:0},
  {tag:'bear',tl:'BAISSIER',txt:'Escalade Mer Rouge · tensions corridors logistiques',tm:'il y a 9h',imp:-0.5},
  {tag:'bull',tl:'HAUSSIER',txt:'SEC retire plainte Coinbase · clarification US',tm:'il y a 11h',imp:1},
];
